---
import type { HTMLAttributes } from 'astro/types';
import { cn } from '@/lib/cn';
import { generateId } from '@/lib/utils';

interface Props extends HTMLAttributes<'input'> {
  label?: string;
  description?: string;
  error?: string;
  variant?: 'default' | 'card';
}

const { label, description, error, variant = 'default', class: className, id, ...attrs } = Astro.props;

const radioId = id || generateId('radio');
const isCard = variant === 'card';
const isChecked = attrs.checked;

const radioStyles = cn(
  'h-4 w-4 shrink-0 rounded-full border border-border',
  'transition-colors duration-[--transition-fast]',
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2',
  'disabled:cursor-not-allowed disabled:opacity-50',
  'checked:border-primary checked:bg-primary',
  error && 'border-destructive focus-visible:ring-destructive'
);

const cardStyles = cn(
  'relative flex cursor-pointer rounded-lg border p-4 transition-all',
  'hover:bg-secondary/50',
  'has-[:checked]:border-primary has-[:checked]:bg-primary/5',
  'has-[:disabled]:cursor-not-allowed has-[:disabled]:opacity-50',
  error && 'border-destructive'
);
---

{isCard ? (
  <label class={cn(cardStyles, className)}>
    <input
      type="radio"
      id={radioId}
      class="peer sr-only"
      aria-invalid={error ? 'true' : undefined}
      aria-describedby={description ? `${radioId}-description` : undefined}
      {...attrs}
    />
    <div class="flex w-full items-start gap-3">
      <div class={cn(
        'mt-0.5 h-4 w-4 shrink-0 rounded-full border border-border transition-colors',
        'peer-checked:border-primary peer-checked:bg-primary peer-checked:shadow-[inset_0_0_0_3px_var(--background)]'
      )} />
      <div class="grid gap-1">
        {label && (
          <span class="text-sm font-medium leading-none">
            {label}
          </span>
        )}
        {description && (
          <p id={`${radioId}-description`} class="text-sm text-muted-foreground">
            {description}
          </p>
        )}
      </div>
    </div>
  </label>
) : (
  <div class={cn('flex items-start gap-3', className)}>
    <input
      type="radio"
      id={radioId}
      class={radioStyles}
      aria-invalid={error ? 'true' : undefined}
      aria-describedby={description ? `${radioId}-description` : undefined}
      {...attrs}
    />

    {
      (label || description) && (
        <div class="grid gap-1.5 leading-none">
          {label && (
            <label
              for={radioId}
              class="text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70"
            >
              {label}
            </label>
          )}
          {description && (
            <p id={`${radioId}-description`} class="text-sm text-muted-foreground">
              {description}
            </p>
          )}
        </div>
      )
    }
  </div>
)}

{
  error && (
    <p class="mt-1.5 text-sm text-destructive">
      {error}
    </p>
  )
}
