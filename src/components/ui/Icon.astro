---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cn(sizes[size], 'shrink-0', className)}
  aria-hidden="true"
>
  {iconPath.split('M').filter(Boolean).map((d) => (
    <path d={`M${d}`} />
  ))}
</svg>
