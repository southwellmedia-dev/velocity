---
/**
 * Footer Component
 * Matches the LandingFooter aesthetic - clean, simple, single-row layout
 * Uses dynamic navigation from routes.ts
 */
import { cn } from '@/lib/cn';
import { getNavRoutes } from '@/config/routes';
import Logo from '@/components/ui/Logo.astro';
import siteConfig from '@/config/site.config';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

// Get navigation routes for footer links
const navRoutes = getNavRoutes();

// External links
const externalLinks = [
  { label: 'GitHub', href: 'https://github.com/southwellmedia/velocity' },
  { label: 'License', href: 'https://github.com/southwellmedia/velocity/blob/main/LICENSE' },
];
---

<footer class={cn('border-t border-border bg-surface-secondary py-12', className)}>
  <div class="mx-auto max-w-6xl px-6 flex flex-col md:flex-row justify-between items-center gap-6">
    <!-- Logo & Attribution -->
    <div class="flex flex-col items-center md:items-start gap-2">
      <a href="/" class="flex items-center gap-2">
        <Logo size="sm" />
        <span class="font-display text-lg font-bold text-brand-500">{siteConfig.name}</span>
      </a>
    </div>

    <!-- Links -->
    <nav class="flex flex-wrap justify-center gap-6 md:gap-8 text-sm text-foreground-muted font-medium">
      <!-- Dynamic routes -->
      {navRoutes.map(({ path, label }) => (
        <a
          href={path}
          class="hover:text-foreground transition-colors"
        >
          {label}
        </a>
      ))}

      <!-- External links -->
      {externalLinks.map((link) => (
        <a
          href={link.href}
          class="hover:text-foreground transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</footer>
