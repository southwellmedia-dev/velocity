---
import PageLayout from '@/layouts/PageLayout.astro';
import Card from '@/components/ui/Card.astro';

const values = [
  {
    title: 'Performance First',
    description: 'Every decision is made with performance in mind. We optimize for Core Web Vitals and real-world loading times.',
    icon: '⚡',
  },
  {
    title: 'Developer Experience',
    description: 'Great tools make great products. We invest in developer experience to enable faster, better development.',
    icon: '🛠️',
  },
  {
    title: 'Accessibility',
    description: 'The web should be for everyone. We build with accessibility as a core requirement, not an afterthought.',
    icon: '♿',
  },
  {
    title: 'Open Source',
    description: 'We believe in giving back to the community. Velocity is open source and free to use.',
    icon: '💚',
  },
];
---

<PageLayout
  title="About Us"
  description="Learn more about our company and mission"
>
  <!-- Hero Section -->
  <section class="py-20">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl font-bold tracking-tight text-foreground mb-6">
          About Us
        </h1>
        <p class="text-xl text-muted-foreground">
          Learn more about our company and mission
        </p>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-12">
    <div class="container">
      <div class="max-w-3xl mx-auto prose prose-lg">
        <h2>Our Story</h2>
        <p>
          Velocity was born out of frustration. As web developers, we found ourselves
          spending hours on boilerplate setup for every new project. SEO configuration,
          internationalization, design tokens—all the things that should "just work"
          required significant effort.
        </p>
        <p>
          We built Velocity to solve this problem. It's the starter template we wished
          existed: modern, fast, and complete. No more piecing together solutions
          from different sources. No more compromising on features because of time
          constraints.
        </p>
        <p>
          Today, Velocity powers dozens of production websites, from small business
          sites to high-traffic applications. And as an open-source project, it's
          constantly improving thanks to contributions from developers around the world.
        </p>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-20 bg-muted/50">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-foreground mb-4">
          Our Values
        </h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          The principles that guide how we build Velocity
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {
          values.map((value) => (
            <Card>
              <div class="text-3xl mb-3">{value.icon}</div>
              <h3 class="text-lg font-semibold text-foreground mb-2">{value.title}</h3>
              <p class="text-muted-foreground">{value.description}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>
</PageLayout>
