---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/Icon.astro';
import { Card, CardTitle, CardDescription } from '@/components/ui/Card';
---

<PageLayout
  title="About Us"
  description="Learn about Velocity and the team behind it."
>
  <!-- Hero Section -->
  <section class="relative pt-16 pb-20 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-grid-pattern [mask-image:linear-gradient(to_bottom,white,transparent)] pointer-events-none opacity-30"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-brand-500/8 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative mx-auto max-w-4xl px-6 text-center">
      <!-- Badge -->
      <div class="mb-6 inline-flex items-center rounded-full border border-border bg-background px-3 py-1 shadow-sm">
        <span class="flex h-2 w-2 rounded-full bg-brand-500 mr-2 animate-pulse"></span>
        <span class="text-xs font-medium text-foreground-secondary">Our Story</span>
      </div>

      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-foreground mb-6">
        Built by developers, <span class="text-brand-500">for developers.</span>
      </h1>

      <p class="text-lg text-foreground-muted max-w-2xl mx-auto mb-8 leading-relaxed">
        Velocity was born from the frustration of setting up the same tooling over and over.
        We decided to create the starter we always wished existed.
      </p>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-20 bg-surface-secondary">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-6">
        Our Mission
      </h2>
      <p class="text-lg text-foreground-muted max-w-2xl mx-auto leading-relaxed">
        To help developers ship beautiful, performant websites faster by eliminating
        boilerplate and providing sensible defaults.
      </p>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-12 text-center">
        What We Believe
      </h2>

      <div class="grid gap-8 md:grid-cols-3">
        <!-- Performance -->
        <Card client:visible hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <CardTitle>Performance First</CardTitle>
              <CardDescription>
                Every decision is made with performance in mind. Zero JavaScript by default,
                optimized images, and minimal CSS.
              </CardDescription>
            </div>
          </div>
        </Card>

        <!-- Simplicity -->
        <Card client:visible hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="box" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <CardTitle>Simplicity Matters</CardTitle>
              <CardDescription>
                We strip away complexity so you can focus on what matters: building
                great products for your users.
              </CardDescription>
            </div>
          </div>
        </Card>

        <!-- Open Source -->
        <Card client:visible hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="github" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <CardTitle>Open Source</CardTitle>
              <CardDescription>
                Velocity is free and open source. We believe in giving back to the
                community that made this possible.
              </CardDescription>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>
</PageLayout>
