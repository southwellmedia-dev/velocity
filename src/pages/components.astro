---
import LandingLayout from '@/layouts/LandingLayout.astro';
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Alert from '@/components/ui/Alert.astro';
import Tabs from '@/components/ui/Tabs.astro';
import VerticalTabs from '@/components/ui/VerticalTabs.astro';
import Dropdown from '@/components/ui/Dropdown.astro';
import Dialog from '@/components/ui/Dialog.astro';
import Tooltip from '@/components/ui/Tooltip.astro';
import Avatar from '@/components/ui/Avatar.astro';
import Skeleton from '@/components/ui/Skeleton.astro';
import Input from '@/components/ui/Input.astro';
import Textarea from '@/components/ui/Textarea.astro';
import Select from '@/components/ui/Select.astro';
import Checkbox from '@/components/ui/Checkbox.astro';
import Radio from '@/components/ui/Radio.astro';
import Card from '@/components/ui/Card.astro';
import { Hero } from '@/components/hero';
import SocialProof from '@/components/ui/SocialProof.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

// Component categories for navigation
const categories = [
  { id: 'hero', label: 'Hero', icon: 'star' },
  { id: 'layout', label: 'Layout', icon: 'layout' },
  { id: 'buttons', label: 'Buttons', icon: 'box' },
  { id: 'inputs', label: 'Form Inputs', icon: 'terminal' },
  { id: 'feedback', label: 'Feedback', icon: 'alert-circle' },
  { id: 'overlays', label: 'Overlays', icon: 'layers' },
  { id: 'navigation', label: 'Navigation', icon: 'menu' },
  { id: 'data', label: 'Data Display', icon: 'layers' },
  { id: 'loading', label: 'Loading', icon: 'loader' },
];
---

<LandingLayout
  title="Components"
  description="Explore Velocity's comprehensive UI component library. Production-ready, accessible, and beautifully designed."
>

  <!-- Hero Section -->
  <Hero
    layout="single"
    align="left"
    size="lg"
    showGrid
    showBlob
    blobPosition="center"
    badge="40+ Production Components"
    badgeIcon
    titleElement="h1"
  >
    <Fragment slot="title">
      Component <span class="text-brand-500">Library</span>
    </Fragment>
    <Fragment slot="description">
      Production-ready UI primitives built with accessibility and performance in mind.
      Copy, paste, and customize to match your brand.
    </Fragment>
    <Fragment slot="actions">
      <Button href="#hero">
        Browse Components
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button variant="outline" href="https://github.com/southwellmedia/velocity" target="_blank">
        <Icon name="github" size="sm" />
        View Source
      </Button>
    </Fragment>
  </Hero>

  <!-- Category Navigation -->
  <nav class="sticky top-16 z-40 bg-background/95 backdrop-blur-md border-y border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex items-center gap-1 py-3 overflow-x-auto scrollbar-hide">
        {categories.map((cat) => (
          <a
            href={`#${cat.id}`}
            class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-foreground-muted hover:text-foreground hover:bg-secondary rounded-md transition-all whitespace-nowrap group"
          >
            <Icon name={cat.icon} size="sm" class="text-foreground-subtle group-hover:text-brand-500 transition-colors" />
            {cat.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Components Showcase -->
  <div class="mx-auto max-w-6xl px-6 py-20 space-y-32">

    <!-- Hero Section -->
    <section id="hero" class="scroll-mt-32">
      <div class="flex items-start gap-5 mb-10">
        <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-brand-500/10 text-brand-500 shrink-0">
          <Icon name="star" size="lg" />
        </div>
        <div>
          <h2 class="font-display text-2xl font-bold text-foreground">Hero</h2>
          <p class="text-foreground-muted mt-1">Flexible hero sections with multiple layouts, backgrounds, and slot-based content injection.</p>
        </div>
      </div>

      <div class="space-y-6">
        <!-- Hero - Split Layout (Default) -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Split Layout</span>
            <span class="showcase-hint">Two-column with aside slot</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Hero
              layout="split"
              align="left"
              size="md"
              showGrid
              badge="New Release"
              badgeIcon
              class="!pt-12 !pb-12"
            >
              <Fragment slot="title">
                Build faster with <span class="text-brand-500">Velocity</span>
              </Fragment>
              <Fragment slot="description">
                A modern starter kit for production websites.
              </Fragment>
              <Fragment slot="actions">
                <Button size="sm">Get Started</Button>
                <Button size="sm" variant="outline">Learn More</Button>
              </Fragment>
              <div slot="aside" class="bg-background-secondary border border-border rounded-lg p-6 text-center">
                <Icon name="code" size="lg" class="text-brand-500 mx-auto mb-2" />
                <p class="text-sm text-foreground-muted">Aside content slot</p>
              </div>
              <SocialProof
                slot="social-proof"
                text="Trusted by developers"
                avatars={[
                  'https://i.pravatar.cc/150?img=12',
                  'https://i.pravatar.cc/150?img=33',
                  'https://i.pravatar.cc/150?img=47',
                ]}
              />
            </Hero>
          </div>
        </div>

        <!-- Hero - Centered Layout -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Centered Layout</span>
            <span class="showcase-hint">Single column, center-aligned</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Hero
              layout="single"
              align="center"
              size="md"
              badge="About Us"
              class="!pt-12 !pb-12"
            >
              <Fragment slot="title">
                We're on a <span class="text-brand-500">mission</span>
              </Fragment>
              <Fragment slot="description">
                Building the tools developers love to use. Our team is dedicated to creating exceptional experiences.
              </Fragment>
              <Fragment slot="actions">
                <Button size="sm">Meet the Team</Button>
                <Button size="sm" variant="ghost">Our Story</Button>
              </Fragment>
            </Hero>
          </div>
        </div>

        <!-- Hero Backgrounds Grid -->
        <div class="grid gap-6 lg:grid-cols-2">
          <!-- Secondary Background -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Secondary Background</span>
            </div>
            <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
              <Hero
                layout="single"
                align="left"
                size="sm"
                background="secondary"
                title="Secondary Background"
                description="Subtle elevation from the default background."
                class="!pt-8 !pb-8"
              />
            </div>
          </div>

          <!-- Gradient Background -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Gradient Background</span>
            </div>
            <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
              <Hero
                layout="single"
                align="left"
                size="sm"
                background="gradient"
                title="Gradient Background"
                description="Smooth gradient transition effect."
                class="!pt-8 !pb-8"
              />
            </div>
          </div>
        </div>

        <!-- Inverted Background (Full Width) -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Inverted Background</span>
            <span class="showcase-hint">Always dark, regardless of theme</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Hero
              layout="single"
              align="center"
              size="sm"
              background="invert"
              class="!pt-10 !pb-10"
            >
              <Fragment slot="title">
                <span class="text-on-invert">Dark mode </span><span class="text-brand-400">always</span>
              </Fragment>
              <Fragment slot="description">
                Perfect for CTAs and sections that need to stand out.
              </Fragment>
              <Fragment slot="actions">
                <Button size="sm">Primary Action</Button>
                <Button size="sm" variant="outline" class="border-border-invert text-on-invert hover:bg-surface-invert-secondary">
                  Secondary
                </Button>
              </Fragment>
              <SocialProof
                slot="social-proof"
                text="Join thousands of users"
                variant="invert"
                avatars={[
                  'https://i.pravatar.cc/150?img=5',
                  'https://i.pravatar.cc/150?img=8',
                  'https://i.pravatar.cc/150?img=11',
                ]}
              />
            </Hero>
          </div>
        </div>

        <!-- Size Variations -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Size Variations</span>
            <span class="showcase-hint">sm, md, lg, xl padding options</span>
          </div>
          <div class="showcase-content">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              {(['sm', 'md', 'lg', 'xl'] as const).map((size) => (
                <div class="border border-border rounded-lg overflow-hidden">
                  <div class="bg-background-secondary px-3 py-1.5 border-b border-border">
                    <span class="text-xs font-mono text-foreground-muted">size="{size}"</span>
                  </div>
                  <div class="bg-background text-center py-2">
                    <span class="text-xs text-foreground-subtle">
                      {size === 'sm' && 'pt-20 pb-12'}
                      {size === 'md' && 'pt-24 pb-16'}
                      {size === 'lg' && 'pt-32 pb-20'}
                      {size === 'xl' && 'pt-40 pb-28'}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Props Reference -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Available Props</span>
            <span class="showcase-hint">Full API reference</span>
          </div>
          <div class="showcase-content">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 text-sm">
              <div>
                <h4 class="font-semibold text-foreground mb-2">Layout</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">align</code> center | left | right</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">layout</code> single | split</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">splitRatio</code> 1:1 | 1:2 | 2:1</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-foreground mb-2">Appearance</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">background</code> default | secondary | invert | gradient | image</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">size</code> sm | md | lg | xl</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showGrid</code> boolean</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showBlob</code> boolean</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-foreground mb-2">Slots</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">badge</code> Top label</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">title</code> Main heading</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">description</code> Supporting text</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">actions</code> CTA buttons</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">aside</code> Side content</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">social-proof</code> Trust indicators</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Layout Section (Header & Footer) -->
    <section id="layout" class="scroll-mt-32">
      <div class="flex items-start gap-5 mb-10">
        <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-brand-500/10 text-brand-500 shrink-0">
          <Icon name="layout" size="lg" />
        </div>
        <div>
          <h2 class="font-display text-2xl font-bold text-foreground">Layout</h2>
          <p class="text-foreground-muted mt-1">Header and Footer components for consistent page structure. Variant-based with full customization via design tokens.</p>
        </div>
      </div>

      <div class="space-y-6">
        <!-- Header Component -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Header Component</span>
            <span class="showcase-hint">Fixed/Sticky with nav, CTA, mobile menu</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <div class="relative border-b border-border">
              <Header
                position="static"
                size="lg"
                showCta
                cta={{ label: 'Get Started', href: '#' }}
                actions={[
                  { icon: 'github', href: '#', label: 'GitHub', iconOnly: true },
                ]}
                extraNav={[{ label: 'Features', href: '#features' }]}
              />
            </div>
          </div>
        </div>

        <!-- Header Variants Grid -->
        <div class="grid gap-6 lg:grid-cols-2">
          <!-- Size Variants -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Size Variants</span>
              <span class="showcase-hint">sm (48px), md (56px), lg (64px)</span>
            </div>
            <div class="showcase-content space-y-3">
              {(['sm', 'md', 'lg'] as const).map((size) => (
                <div class="border border-border rounded-lg overflow-hidden">
                  <div class="bg-background-secondary px-3 py-1.5 border-b border-border">
                    <span class="text-xs font-mono text-foreground-muted">size="{size}"</span>
                  </div>
                  <Header
                    position="static"
                    size={size}
                    showMobileMenu={false}
                    nav={[{ label: 'Components', href: '/components' }]}
                  />
                </div>
              ))}
            </div>
          </div>

          <!-- Background Variants -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Background Variants</span>
              <span class="showcase-hint">default, solid, transparent</span>
            </div>
            <div class="showcase-content space-y-3">
              <div class="border border-border rounded-lg overflow-hidden">
                <div class="bg-background-secondary px-3 py-1.5 border-b border-border">
                  <span class="text-xs font-mono text-foreground-muted">variant="default"</span>
                </div>
                <Header position="static" size="sm" variant="default" showMobileMenu={false} nav={[]} />
              </div>
              <div class="border border-border rounded-lg overflow-hidden">
                <div class="bg-background-secondary px-3 py-1.5 border-b border-border">
                  <span class="text-xs font-mono text-foreground-muted">variant="solid"</span>
                </div>
                <Header position="static" size="sm" variant="solid" showMobileMenu={false} nav={[]} />
              </div>
              <div class="border border-border rounded-lg overflow-hidden bg-gradient-to-r from-brand-500 to-brand-600">
                <div class="bg-black/20 px-3 py-1.5 border-b border-white/10">
                  <span class="text-xs font-mono text-white/80">variant="transparent"</span>
                </div>
                <Header position="static" size="sm" variant="transparent" showMobileMenu={false} nav={[]} />
              </div>
            </div>
          </div>
        </div>

        <!-- Header Props Reference -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Header Props</span>
            <span class="showcase-hint">Full API reference</span>
          </div>
          <div class="showcase-content">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 text-sm">
              <div>
                <h4 class="font-semibold text-foreground mb-2">Layout & Position</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">layout</code> default | centered | minimal</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">position</code> fixed | sticky | static</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">size</code> sm | md | lg</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">variant</code> default | solid | transparent</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-foreground mb-2">Navigation</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">nav</code> NavItem[] (overrides routes)</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">extraNav</code> NavItem[] (adds to routes)</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showActiveState</code> boolean</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showMobileMenu</code> boolean</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-foreground mb-2">Actions</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showCta</code> boolean</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">cta</code> {'{ label, href }'}</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">actions</code> HeaderAction[]</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showThemeToggle</code> boolean</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Footer Component -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Footer - Simple Layout</span>
            <span class="showcase-hint">Single row with logo, nav, optional social</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Footer
              layout="simple"
              background="secondary"
              showCopyright={false}
              socialLinks={[
                { platform: 'github', href: '#' },
                { platform: 'twitter', href: '#' },
              ]}
            />
          </div>
        </div>

        <!-- Footer Layouts Grid -->
        <div class="grid gap-6 lg:grid-cols-2">
          <!-- Minimal Layout -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Minimal Layout</span>
              <span class="showcase-hint">Copyright only</span>
            </div>
            <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
              <Footer
                layout="minimal"
                copyright="© {year} {siteName}"
              />
            </div>
          </div>

          <!-- Stacked Layout -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Stacked Layout</span>
              <span class="showcase-hint">Vertically stacked, centered</span>
            </div>
            <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
              <Footer
                layout="stacked"
                tagline="Build faster, ship with confidence"
                socialLinks={[
                  { platform: 'github', href: '#' },
                  { platform: 'twitter', href: '#' },
                ]}
                legalLinks={[
                  { label: 'Privacy', href: '#' },
                  { label: 'Terms', href: '#' },
                ]}
              />
            </div>
          </div>
        </div>

        <!-- Footer Columns Layout -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Columns Layout</span>
            <span class="showcase-hint">Multi-column with link groups</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Footer
              layout="columns"
              columns={4}
              tagline="Modern starter kit for production websites"
              socialLinks={[
                { platform: 'github', href: '#' },
                { platform: 'twitter', href: '#' },
              ]}
              linkGroups={[
                {
                  title: 'Product',
                  links: [
                    { label: 'Features', href: '#' },
                    { label: 'Pricing', href: '#' },
                    { label: 'Docs', href: '#' },
                  ],
                },
                {
                  title: 'Company',
                  links: [
                    { label: 'About', href: '#' },
                    { label: 'Blog', href: '#' },
                    { label: 'Careers', href: '#' },
                  ],
                },
                {
                  title: 'Legal',
                  links: [
                    { label: 'Privacy', href: '#' },
                    { label: 'Terms', href: '#' },
                  ],
                },
              ]}
              legalLinks={[
                { label: 'Privacy Policy', href: '#' },
                { label: 'Terms of Service', href: '#' },
              ]}
            />
          </div>
        </div>

        <!-- Footer Props Reference -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Footer Props</span>
            <span class="showcase-hint">Full API reference</span>
          </div>
          <div class="showcase-content">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 text-sm">
              <div>
                <h4 class="font-semibold text-foreground mb-2">Layout</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">layout</code> simple | columns | minimal | stacked</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">columns</code> 2 | 3 | 4</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">background</code> default | secondary | invert</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-foreground mb-2">Content</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">nav</code> NavItem[]</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">linkGroups</code> FooterLinkGroup[]</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">socialLinks</code> SocialLink[]</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">tagline</code> string</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-foreground mb-2">Copyright & Legal</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showCopyright</code> boolean</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">copyright</code> string (supports {'{year}'}, {'{siteName}'})</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">legalLinks</code> LegalLink[]</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Design Tokens -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Navigation Design Tokens</span>
            <span class="showcase-hint">Customize via CSS custom properties</span>
          </div>
          <div class="showcase-content">
            <div class="bg-background-secondary rounded-lg p-4 font-mono text-xs space-y-1 text-foreground-muted overflow-x-auto">
              <p class="text-foreground-subtle">/* Customize nav link states in global.css */</p>
              <p>--nav-link-color: var(--foreground-muted);</p>
