---
import LandingLayout from '@/layouts/LandingLayout.astro';
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Alert from '@/components/ui/Alert.astro';
import Tabs from '@/components/ui/Tabs.astro';
import Dropdown from '@/components/ui/Dropdown.astro';
import Dialog from '@/components/ui/Dialog.astro';
import Tooltip from '@/components/ui/Tooltip.astro';
import Avatar from '@/components/ui/Avatar.astro';
import Skeleton from '@/components/ui/Skeleton.astro';
import Input from '@/components/ui/Input.astro';
import Textarea from '@/components/ui/Textarea.astro';
import Select from '@/components/ui/Select.astro';
import Checkbox from '@/components/ui/Checkbox.astro';
import Radio from '@/components/ui/Radio.astro';
import Card from '@/components/ui/Card.astro';
import { Hero } from '@/components/hero';
import SocialProof from '@/components/ui/SocialProof.astro';

// Component categories for navigation
const categories = [
  { id: 'hero', label: 'Hero', icon: 'star' },
  { id: 'buttons', label: 'Buttons', icon: 'box' },
  { id: 'inputs', label: 'Form Inputs', icon: 'terminal' },
  { id: 'feedback', label: 'Feedback', icon: 'alert-circle' },
  { id: 'overlays', label: 'Overlays', icon: 'layers' },
  { id: 'data', label: 'Data Display', icon: 'layout' },
  { id: 'loading', label: 'Loading', icon: 'loader' },
];
---

<LandingLayout
  title="Components"
  description="Explore Velocity's comprehensive UI component library. Production-ready, accessible, and beautifully designed."
>

  <!-- Hero Section -->
  <Hero
    layout="single"
    align="left"
    size="lg"
    showGrid
    showBlob
    blobPosition="center"
    badge="40+ Production Components"
    badgeIcon
    titleElement="h1"
  >
    <Fragment slot="title">
      Component <span class="text-brand-500">Library</span>
    </Fragment>
    <Fragment slot="description">
      Production-ready UI primitives built with accessibility and performance in mind.
      Copy, paste, and customize to match your brand.
    </Fragment>
    <Fragment slot="actions">
      <Button href="#hero">
        Browse Components
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button variant="outline" href="https://github.com/southwellmedia/velocity" target="_blank">
        <Icon name="github" size="sm" />
        View Source
      </Button>
    </Fragment>
  </Hero>

  <!-- Category Navigation -->
  <nav class="sticky top-16 z-40 bg-background/95 backdrop-blur-md border-y border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex items-center gap-1 py-3 overflow-x-auto scrollbar-hide">
        {categories.map((cat) => (
          <a
            href={`#${cat.id}`}
            class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-foreground-muted hover:text-foreground hover:bg-secondary rounded-md transition-all whitespace-nowrap group"
          >
            <Icon name={cat.icon} size="sm" class="text-foreground-subtle group-hover:text-brand-500 transition-colors" />
            {cat.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Components Showcase -->
  <div class="mx-auto max-w-6xl px-6 py-20 space-y-32">

    <!-- Hero Section -->
    <section id="hero" class="scroll-mt-32">
      <div class="flex items-start gap-5 mb-10">
        <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-brand-500/10 text-brand-500 shrink-0">
          <Icon name="star" size="lg" />
        </div>
        <div>
          <h2 class="font-display text-2xl font-bold text-foreground">Hero</h2>
          <p class="text-foreground-muted mt-1">Flexible hero sections with multiple layouts, backgrounds, and slot-based content injection.</p>
        </div>
      </div>

      <div class="space-y-6">
        <!-- Hero - Split Layout (Default) -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Split Layout</span>
            <span class="showcase-hint">Two-column with aside slot</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Hero
              layout="split"
              align="left"
              size="md"
              showGrid
              badge="New Release"
              badgeIcon
              class="!pt-12 !pb-12"
            >
              <Fragment slot="title">
                Build faster with <span class="text-brand-500">Velocity</span>
              </Fragment>
              <Fragment slot="description">
                A modern starter kit for production websites.
              </Fragment>
              <Fragment slot="actions">
                <Button size="sm">Get Started</Button>
                <Button size="sm" variant="outline">Learn More</Button>
              </Fragment>
              <div slot="aside" class="bg-background-secondary border border-border rounded-lg p-6 text-center">
                <Icon name="code" size="lg" class="text-brand-500 mx-auto mb-2" />
                <p class="text-sm text-foreground-muted">Aside content slot</p>
              </div>
              <SocialProof
                slot="social-proof"
                text="Trusted by developers"
                avatars={[
                  'https://i.pravatar.cc/150?img=12',
                  'https://i.pravatar.cc/150?img=33',
                  'https://i.pravatar.cc/150?img=47',
                ]}
              />
            </Hero>
          </div>
        </div>

        <!-- Hero - Centered Layout -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Centered Layout</span>
            <span class="showcase-hint">Single column, center-aligned</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Hero
              layout="single"
              align="center"
              size="md"
              badge="About Us"
              class="!pt-12 !pb-12"
            >
              <Fragment slot="title">
                We're on a <span class="text-brand-500">mission</span>
              </Fragment>
              <Fragment slot="description">
                Building the tools developers love to use. Our team is dedicated to creating exceptional experiences.
              </Fragment>
              <Fragment slot="actions">
                <Button size="sm">Meet the Team</Button>
                <Button size="sm" variant="ghost">Our Story</Button>
              </Fragment>
            </Hero>
          </div>
        </div>

        <!-- Hero Backgrounds Grid -->
        <div class="grid gap-6 lg:grid-cols-2">
          <!-- Secondary Background -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Secondary Background</span>
            </div>
            <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
              <Hero
                layout="single"
                align="left"
                size="sm"
                background="secondary"
                title="Secondary Background"
                description="Subtle elevation from the default background."
                class="!pt-8 !pb-8"
              />
            </div>
          </div>

          <!-- Gradient Background -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Gradient Background</span>
            </div>
            <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
              <Hero
                layout="single"
                align="left"
                size="sm"
                background="gradient"
                title="Gradient Background"
                description="Smooth gradient transition effect."
                class="!pt-8 !pb-8"
              />
            </div>
          </div>
        </div>

        <!-- Inverted Background (Full Width) -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Inverted Background</span>
            <span class="showcase-hint">Always dark, regardless of theme</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Hero
              layout="single"
              align="center"
              size="sm"
              background="invert"
              class="!pt-10 !pb-10"
            >
              <Fragment slot="title">
                <span class="text-on-invert">Dark mode </span><span class="text-brand-400">always</span>
              </Fragment>
              <Fragment slot="description">
                Perfect for CTAs and sections that need to stand out.
              </Fragment>
              <Fragment slot="actions">
                <Button size="sm">Primary Action</Button>
                <Button size="sm" variant="outline" class="border-border-invert text-on-invert hover:bg-surface-invert-secondary">
                  Secondary
                </Button>
              </Fragment>
              <SocialProof
                slot="social-proof"
                text="Join thousands of users"
                variant="invert"
                avatars={[
                  'https://i.pravatar.cc/150?img=5',
                  'https://i.pravatar.cc/150?img=8',
                  'https://i.pravatar.cc/150?img=11',
                ]}
              />
            </Hero>
          </div>
        </div>

        <!-- Size Variations -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Size Variations</span>
            <span class="showcase-hint">sm, md, lg, xl padding options</span>
          </div>
          <div class="showcase-content">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              {(['sm', 'md', 'lg', 'xl'] as const).map((size) => (
                <div class="border border-border rounded-lg overflow-hidden">
                  <div class="bg-background-secondary px-3 py-1.5 border-b border-border">
                    <span class="text-xs font-mono text-foreground-muted">size="{size}"</span>
                  </div>
                  <div class="bg-background text-center py-2">
                    <span class="text-xs text-foreground-subtle">
                      {size === 'sm' && 'pt-20 pb-12'}
                      {size === 'md' && 'pt-24 pb-16'}
                      {size === 'lg' && 'pt-32 pb-20'}
                      {size === 'xl' && 'pt-40 pb-28'}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Props Reference -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Available Props</span>
            <span class="showcase-hint">Full API reference</span>
          </div>
          <div class="showcase-content">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 text-sm">
              <div>
                <h4 class="font-semibold text-foreground mb-2">Layout</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">align</code> center | left | right</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">layout</code> single | split</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">splitRatio</code> 1:1 | 1:2 | 2:1</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-foreground mb-2">Appearance</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">background</code> default | secondary | invert | gradient | image</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">size</code> sm | md | lg | xl</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showGrid</code> boolean</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showBlob</code> boolean</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-foreground mb-2">Slots</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">badge</code> Top label</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">title</code> Main heading</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">description</code> Supporting text</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">actions</code> CTA buttons</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">aside</code> Side content</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">social-proof</code> Trust indicators</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Buttons Section -->
    <section id="buttons" class="scroll-mt-32">
      <div class="flex items-start gap-5 mb-10">
        <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-brand-500/10 text-brand-500 shrink-0">
          <Icon name="box" size="lg" />
        </div>
        <div>
          <h2 class="font-display text-2xl font-bold text-foreground">Buttons</h2>
          <p class="text-foreground-muted mt-1">Interactive elements for actions and navigation. All variants support icons, loading states, and full accessibility.</p>
        </div>
      </div>

      <div class="space-y-6">
        <!-- Button Variants -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Variants</span>
            <span class="showcase-hint">6 styles for different contexts</span>
          </div>
          <div class="showcase-content">
            <div class="flex flex-wrap items-center gap-3">
              <Button variant="primary">Primary</Button>
              <Button variant="secondary">Secondary</Button>
              <Button variant="outline">Outline</Button>
              <Button variant="ghost">Ghost</Button>
              <Button variant="link">Link</Button>
              <Button variant="destructive">Destructive</Button>
            </div>
          </div>
        </div>

        <!-- Button Sizes -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Sizes</span>
            <span class="showcase-hint">Responsive scaling</span>
          </div>
          <div class="showcase-content">
            <div class="flex flex-wrap items-end gap-3">
              <Button size="sm">Small</Button>
              <Button size="md">Medium</Button>
              <Button size="lg">Large</Button>
            </div>
          </div>
        </div>

        <!-- Button States & Icons -->
        <div class="grid gap-6 lg:grid-cols-2">
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">States</span>
            </div>
            <div class="showcase-content">
              <div class="flex flex-wrap items-center gap-3">
                <Button>Default</Button>
                <Button loading>Loading</Button>
                <Button disabled>Disabled</Button>
                <Button icon><Icon name="plus" /></Button>
              </div>
            </div>
          </div>

          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">With Icons</span>
            </div>
            <div class="showcase-content">
              <div class="flex flex-wrap items-center gap-3">
                <Button><Icon name="mail" size="sm" /> Send</Button>
                <Button variant="outline"><Icon name="download" size="sm" /> Export</Button>
                <Button variant="ghost"><Icon name="star" size="sm" /> Star</Button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Form Inputs Section -->
    <section id="inputs" class="scroll-mt-32">
      <div class="flex items-start gap-5 mb-10">
        <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-brand-500/10 text-brand-500 shrink-0">
          <Icon name="terminal" size="lg" />
        </div>
        <div>
          <h2 class="font-display text-2xl font-bold text-foreground">Form Inputs</h2>
          <p class="text-foreground-muted mt-1">Text fields, selects, checkboxes, and more. Built with native validation and ARIA support.</p>
        </div>
      </div>

      <div class="space-y-6">
        <div class="grid gap-6 lg:grid-cols-2">
          <!-- Text Input -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Text Input</span>
              <span class="showcase-hint">With labels & validation</span>
            </div>
            <div class="showcase-content space-y-5">
              <Input label="Email address" type="email" placeholder="you@example.com" />
              <Input label="Password" type="password" placeholder="••••••••" hint="Must be at least 8 characters" />
              <Input label="Disabled" placeholder="Cannot edit" disabled />
            </div>
          </div>

          <!-- Textarea -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Textarea</span>
              <span class="showcase-hint">Multi-line text input</span>
            </div>
            <div class="showcase-content">
              <Textarea label="Message" placeholder="Write your message here..." rows={5} hint="Supports markdown formatting" />
            </div>
          </div>

          <!-- Select -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Select</span>
              <span class="showcase-hint">Native dropdown</span>
            </div>
            <div class="showcase-content">
              <Select label="Country" options={[
                { value: '', label: 'Select a country...' },
                { value: 'us', label: 'United States' },
                { value: 'uk', label: 'United Kingdom' },
                { value: 'ca', label: 'Canada' },
                { value: 'de', label: 'Germany' },
                { value: 'fr', label: 'France' },
              ]} />
            </div>
          </div>

          <!-- Checkboxes -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Checkboxes</span>
              <span class="showcase-hint">Multi-select controls</span>
            </div>
            <div class="showcase-content space-y-4">
              <Checkbox label="I agree to the terms of service" />
              <Checkbox label="Send me product updates" checked />
              <Checkbox label="Enable notifications" description="Receive alerts for important updates" />
            </div>
          </div>
        </div>

        <!-- Radio Cards - Full width -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Plan Selection</span>
            <span class="showcase-hint">Card-style radio options</span>
          </div>
          <div class="showcase-content">
            <div class="grid gap-4 sm:grid-cols-3">
              <Radio variant="card" name="plan-cards" value="free" label="Free" description="Basic features for personal projects" checked />
              <Radio variant="card" name="plan-cards" value="pro" label="Pro" description="Advanced tools for professionals" />
              <Radio variant="card" name="plan-cards" value="team" label="Team" description="Collaboration features for teams" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Feedback Section -->
    <section id="feedback" class="scroll-mt-32">
      <div class="flex items-start gap-5 mb-10">
        <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-brand-500/10 text-brand-500 shrink-0">
          <Icon name="alert-circle" size="lg" />
        </div>
        <div>
          <h2 class="font-display text-2xl font-bold text-foreground">Feedback</h2>
          <p class="text-foreground-muted mt-1">Badges, alerts, and status indicators to communicate state and guide user actions.</p>
        </div>
      </div>

      <div class="space-y-6">
        <!-- Badges -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Badges</span>
            <span class="showcase-hint">Status indicators</span>
          </div>
          <div class="showcase-content">
            <div class="flex flex-wrap items-center gap-3">
              <Badge>Default</Badge>
              <Badge variant="success">
                <Icon name="check" size="xs" />
                Success
              </Badge>
              <Badge variant="warning">
                <Icon name="alert-triangle" size="xs" />
                Warning
              </Badge>
              <Badge variant="error">
                <Icon name="x-circle" size="xs" />
                Error
              </Badge>
              <Badge variant="info">
                <Icon name="info" size="xs" />
                Info
              </Badge>
            </div>
          </div>
        </div>

        <!-- Alerts -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Alerts</span>
            <span class="showcase-hint">Contextual messages</span>
          </div>
          <div class="showcase-content space-y-4">
            <Alert variant="info" title="Tip">
              Use keyboard shortcuts to navigate faster. Press <kbd class="px-1.5 py-0.5 text-xs font-mono bg-background-secondary rounded border border-border">⌘K</kbd> to open the command palette.
            </Alert>
            <Alert variant="success" title="Deployment successful">
              Your changes are now live at <span class="underline underline-offset-2">your-app.vercel.app</span>
            </Alert>
            <Alert variant="warning" title="Approaching limit">
              You've used 80% of your monthly API quota. Consider upgrading your plan.
            </Alert>
            <Alert variant="error" title="Build failed" dismissible>
              Error in <code class="text-xs font-mono">src/components/Button.tsx</code> — missing required prop "variant"
            </Alert>
          </div>
        </div>
      </div>
    </section>

    <!-- Overlays Section -->
    <section id="overlays" class="scroll-mt-32">
      <div class="flex items-start gap-5 mb-10">
        <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-brand-500/10 text-brand-500 shrink-0">
          <Icon name="layers" size="lg" />
        </div>
        <div>
          <h2 class="font-display text-2xl font-bold text-foreground">Overlays</h2>
          <p class="text-foreground-muted mt-1">Dialogs, dropdowns, tooltips, and tabs. Full keyboard navigation and focus management.</p>
        </div>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <!-- Dialog -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Dialog</span>
            <span class="showcase-hint">Modal overlay</span>
          </div>
          <div class="showcase-content">
            <Button onclick="openDialog('demo-dialog')">
              <Icon name="external-link" size="sm" />
              Open Dialog
            </Button>

            <Dialog id="demo-dialog" title="Delete project?" description="This action cannot be undone.">
              <p class="text-foreground-muted text-sm">
                Are you sure you want to delete <strong class="text-foreground">velocity-demo</strong>? All files, deployments, and analytics data will be permanently removed.
              </p>
              <div class="flex justify-end gap-3 pt-6">
                <Button variant="outline" onclick="closeDialog('demo-dialog')">Cancel</Button>
                <Button variant="destructive" onclick="closeDialog('demo-dialog')">
                  <Icon name="x" size="sm" />
                  Delete Project
                </Button>
              </div>
            </Dialog>
          </div>
        </div>

        <!-- Dropdown -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Dropdown</span>
            <span class="showcase-hint">Action menu</span>
          </div>
          <div class="showcase-content">
            <Dropdown
              items={[
                { label: 'Edit', href: '#', icon: 'edit' },
                { label: 'Duplicate', href: '#', icon: 'copy' },
                { label: 'Share', href: '#', icon: 'share' },
                { separator: true, label: '' },
                { label: 'Archive', href: '#', icon: 'archive' },
                { label: 'Delete', href: '#', disabled: true, icon: 'trash' },
              ]}
            >
              <Button variant="outline" slot="trigger">
                Actions
                <Icon name="chevron-down" size="sm" />
              </Button>
            </Dropdown>
          </div>
        </div>

        <!-- Tooltips -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Tooltips</span>
            <span class="showcase-hint">Contextual hints</span>
          </div>
          <div class="showcase-content">
            <div class="flex flex-wrap items-center gap-4">
              <Tooltip content="Tooltip on top" position="top">
                <Button variant="outline" size="sm">Top</Button>
              </Tooltip>
              <Tooltip content="Tooltip on bottom" position="bottom">
                <Button variant="outline" size="sm">Bottom</Button>
              </Tooltip>
              <Tooltip content="Tooltip on left" position="left">
                <Button variant="outline" size="sm">Left</Button>
              </Tooltip>
              <Tooltip content="Tooltip on right" position="right">
                <Button variant="outline" size="sm">Right</Button>
              </Tooltip>
            </div>
          </div>
        </div>

        <!-- Tabs -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Tabs</span>
            <span class="showcase-hint">Content organization</span>
          </div>
          <div class="showcase-content">
            <Tabs
              tabs={[
                { id: 'overview', label: 'Overview' },
